{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JSON Tools",
  "version": "1.0.0",
  "identifier": "com.jsontools.dev",
  "build": {
    "frontendDist": "../src/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "scripts\\dev-frontend.bat",
    "beforeBuildCommand": "scripts\\build-frontend.bat"
  },
  "app": {
    "windows": [
      {
        "title": "JSON Tools",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installerHooks": "installer.nsh"
      }
    },
    "resources": ["resources/WebView2Loader.dll"]
  }
}
